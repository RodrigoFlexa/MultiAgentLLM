# Copie este arquivo para `.env` e ajuste conforme a máquina.

# Qual(is) GPU(s) o processo deve usar (índice físico, conforme `nvidia-smi`).
# "0"     -> usa só a GPU 0
# "1"     -> usa só a GPU 1
# "0,1"   -> torna ambas visíveis (útil com device_map="auto" para sharding)
# (vazio) -> usa todas as GPUs visíveis na máquina
CUDA_VISIBLE_DEVICES=0

# Backend de inferência: "hf" (HuggingFace Transformers, precisa de GPU) ou
# "mock" (falso, sem GPU, só para testar o encanamento).
MULTIAGENT_BACKEND=hf

# dtype usado pelo Transformers ao carregar os modelos.
MULTIAGENT_DTYPE=bfloat16

# Carregar o master em 4-bit (bitsandbytes). "1" para ativar.
MASTER_4BIT=0
